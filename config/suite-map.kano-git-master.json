{
  "rules": [
    { "suite": "bdd-scenarios", "match": { "any": ["[bdd]", "scenario:", "KOG-BDD-", "ScenarioRecorder", "Given ", "When ", "Then "] } },
    { "suite": "bdd-featured", "match": { "any": ["[featured]", "featured scenario", "docVisibility=public", "featured=true"] } },
    { "suite": "tdd-unit", "match": { "any": ["[tdd]", "[unit]", "unit", "kano_git_tui_tests", "kano_git_commit_plan_tests"] } },
    { "suite": "ai-provider-bootstrap", "match": { "any": ["feature:ai-provider-bootstrap", "KOG-BDD-AI-", "ai provider", "provider bootstrap", "copilot"] } },
    { "suite": "ai-model-resolution", "match": { "any": ["feature:ai-model-resolution", "model-resolution", "model-selection", "model-args", "provider-auto", "kog-auto"] } },
    { "suite": "converge", "match": { "any": ["feature:converge", "KOG-BDD-CONVERGE-", "converge", "cpa"] } },
    { "suite": "converge-state", "match": { "any": ["feature:converge-state", "converge state", "workflow state", "resume", "abort"] } },
    { "suite": "status-policy", "match": { "any": ["feature:status-policy", "KOG-BDD-STATUS-", "status policy", "dirty detection", "behind remote"] } },
    { "suite": "dirty-kind", "match": { "any": ["feature:dirty-kind", "dirtyKind", "UNTRACKED_ONLY", "GITLINK_DIRTY", "CONFLICTED", "BEHIND_ONLY", "AHEAD_ONLY"] } },
    { "suite": "discovery", "match": { "any": ["feature:discovery", "KOG-BDD-DISCOVERY-", "workspace discover", "repo discovery", "submodule", "subrepo", "external-root"] } },
    { "suite": "repo-operation-scheduler", "match": { "any": ["feature:repo-operation-scheduler", "repo operation scheduler", "RunRepoOperationScheduler", "dependency waves", "common-dir locks"] } },
    { "suite": "repo-discovery", "match": { "any": ["workspace discover", "repo discovery", "submodule", "subrepo", "external-root"] } },
    { "suite": "status-log", "match": { "any": ["repo status", "status", "log", "diff", "remote preview", "behind remote"] } },
    { "suite": "fetch-sync", "match": { "any": ["fetch", "sync", "origin-latest", "recursive workspace fetch"] } },
    { "suite": "commit-plan", "match": { "any": ["plan runbook", "plan verify", "commit plan", "plan-stage", "empty plan"] } },
    { "suite": "commit-push", "match": { "any": ["commit-push", "native-commit", "push summary", "dirty detection", "staging", "secret gate"] } },
    { "suite": "export-package", "match": { "any": ["export", "archive", "manifest", "release archive smoke", "subrepo expansion"] } },
    { "suite": "tui", "match": { "any": ["kano_git_tui_tests", "tui", "command mode", "metadata cache", "shell-executor"] } },
    { "suite": "coverage-pgo", "match": { "any": ["coverage", "cobertura", "pgo", "opencppcoverage", "microsoft-code-coverage"] } },
    { "suite": "infra", "match": { "any": ["pixi", "launcher", "wrapper", "path", "platform", "bootstrap", "report"] } },
    { "suite": "generated-property", "match": { "any": ["synthetic", "generated", "property", "[Property]"] } },
    { "suite": "external-optional", "match": { "any": ["github api", "copilot", "network", "external", "integration"] } },
    { "suite": "cli-core", "match": { "any": ["kano_git_cli_tests", "unknown command", "help", "argument", "entrypoint"] } }
  ]
}
